# Copy to .env.local for development. Every variable the app reads lives in
# src/lib/env.ts; docs/OPS.md has the production notes for each one.

# --- Core ---------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5433/minnekart
# Public base URL. Builds invite/share/reset links and OG image URLs.
APP_URL=http://localhost:3000

# --- Email --------------------------------------------------------------
# 'console' logs messages (dev), 'memory' captures them (tests), 'smtp'
# sends for real. Set SMTP_* + EMAIL_FROM when EMAIL_TRANSPORT=smtp.
EMAIL_TRANSPORT=console
# Brevo example (587 = STARTTLS, works from Vercel serverless):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=Minnekart <hello@yourdomain.com>

# --- Photo storage ------------------------------------------------------
# Object storage for photos. Use 'memory' for local dev without R2.
# Defaults to 'r2' when unset, so keep this line in dev.
STORAGE_DRIVER=memory
# Set STORAGE_DRIVER=r2 and fill these to use a real Cloudflare R2 bucket:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# --- Billing (Paddle) ---------------------------------------------------
# 'sandbox' | 'production'. Defaults to 'sandbox'.
PADDLE_ENV=sandbox
# Notification destination secret (pdl_ntfset_…). Without it the webhook
# route returns 503 and no plan changes apply.
# PADDLE_WEBHOOK_SECRET=
# Client-side token (test_… / live_…). Public-safe; opens the checkout.
# PADDLE_CLIENT_TOKEN=
# Price ids (pri_…). The checkout buttons hide without PADDLE_PRICE_ANNUAL.
# PADDLE_PRICE_ANNUAL=
# PADDLE_PRICE_MONTHLY=
# Unset PADDLE_PRICE_LIFETIME to retire the founding-member offer.
# PADDLE_PRICE_LIFETIME=

# --- Business identity --------------------------------------------------
# Printed on /terms, /privacy and /refunds, which Paddle reviews before it
# approves a live account. Keep the real values out of the repo: set them in
# .env locally and in Vercel for production. Unset, the pages fall back to
# obvious placeholders ("HHO", "ABN XXXX XXXX XXX").
# LEGAL_ENTITY_NAME=
# LEGAL_ENTITY_ABN=

# --- Signup mode + CAPTCHA ----------------------------------------------
# 'true' | 'false'. Defaults to 'false' (invite-only). Setting 'true' in
# production is the public-launch moment.
OPEN_SIGNUP=false
# Cloudflare Turnstile. Set both keys or neither; when the secret is set,
# signups without a valid token are rejected. The always-pass test keys:
# TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
